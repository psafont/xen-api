(executable
 (name networkd)
 (modes exe)
 (libraries
  astring
  dune-build-info
  forkexec
  http_lib
  integers
  netlink
  networklibs
  rpclib.core
  rpclib.json
  result
  rresult
  systemd
  threads.posix
  xapi-client
  xapi-consts
  xapi-consts.xapi_version
  xapi-stdext-pervasives
  xapi-stdext-std
  xapi-stdext-threads
  xapi-stdext-unix
  xapi-inventory
  xapi-idl
  xapi-idl.network
  xapi-log
  xapi-types
  xen-api-client))

(rule
 (with-stdout-to
  xcp-networkd.1
  (run %{dep:networkd.exe} --help=groff)
 )
)

(rule
 (target xcp-networkd.1.gz)
 (deps (:man xcp-networkd.1))
 (action
  (with-stdout-to %{target} (with-stdin-from %{man} (run gzip))))
)

(install
 (section sbin)
 (files (networkd.exe as xapi-networkd))
 (package xapi-networkd)
)

(install
 (section man)
 (files xcp-networkd.1.gz)
 (package xapi-networkd)
)
